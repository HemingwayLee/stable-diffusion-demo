# HuggingFace access token
# 1. Accept the license at https://huggingface.co/stabilityai/stable-diffusion-3.5-medium
# 2. Create a token at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Model to load (medium is ~6 GB, large is ~24 GB)
MODEL_ID=stabilityai/stable-diffusion-3.5-medium

# Inference device: cuda | mps | cpu  (leave blank to auto-detect)
DEVICE=

# Set to true to use CPU offloading on CUDA (saves VRAM, ~20% slower)
LOW_VRAM=false

# PostgreSQL credentials
POSTGRES_USER=sduser
POSTGRES_PASSWORD=sdpassword
POSTGRES_DB=sddb
